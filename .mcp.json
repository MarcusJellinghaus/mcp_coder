{
  "mcpServers": {
    "tools-py": {
      "type": "stdio",
      "command": "${VIRTUAL_ENV}\\Scripts\\mcp-tools-py.exe",
      "args": [
        "--project-dir",
        "${MCP_CODER_PROJECT_DIR}",
        "--python-executable",
        "${VIRTUAL_ENV}\\Scripts\\python.exe",
        "--venv-path",
        "${VIRTUAL_ENV}",
        "--test-folder",
        "tests",
        "--log-level",
        "INFO"
      ],
      "env": {
        "PYTHONPATH": "${MCP_CODER_PROJECT_DIR}/src"
      }
    },
    "workspace": {
      "type": "stdio",
      "command": "${VIRTUAL_ENV}/Scripts/mcp-workspace.exe",
      "args": [
        "--project-dir",
        "${MCP_CODER_PROJECT_DIR}",
        "--log-level",
        "INFO",
        "--reference-project",
        "p_workspace=${USERPROFILE}\\Documents\\GitHub\\mcp-workspace",
        "--reference-project",
        "p_config=${USERPROFILE}\\Documents\\GitHub\\mcp-config",
        "--reference-project",
        "p_tools=${USERPROFILE}\\Documents\\GitHub\\mcp-tools-py"
      ],
      "env": {
        "PYTHONPATH": "${VIRTUAL_ENV}\\Lib\\"
      }
    }
  }
}